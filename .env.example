# Copy this file to `.env.local` and fill in your own values.
# All NEXT_PUBLIC_* vars are exposed to the browser (that is expected for a
# Firebase web app). Your data is protected by Firestore Security Rules, not by
# hiding these values.

# --- Firebase (from your Firebase project settings → Web app config) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- CoinGecko ---
# No key required: the app uses CoinGecko's free public API (keyless).
# Do NOT add a CoinGecko key as a NEXT_PUBLIC_ var — unlike Firebase web keys,
# a CoinGecko key is a real secret and NEXT_PUBLIC_ would expose it in the
# browser bundle. If you ever need higher rate limits, proxy CoinGecko through
# a server-side route handler using a non-public CG_KEY instead.

# --- News ---
# No key required: news is fetched server-side by app/api/news/route.js from
# public RSS feeds (CoinDesk, Cointelegraph, Decrypt).
